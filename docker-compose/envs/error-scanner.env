# =============================================================================
# Error Scanner Configuration
# =============================================================================
# This file contains all configuration for the error log scanner service.
# Configuration priority: Environment variables > This file > Script defaults
#
# To override settings, either:
# 1. Set environment variables in docker-compose.yml
# 2. Modify values in this file
# 3. Use environment variables when running the script directly
# =============================================================================

# -----------------------------------------------------------------------------
# S3 Configuration
# -----------------------------------------------------------------------------
# S3 bucket for storing error logs
S3_ERROR_LOGS_BUCKET=oasys-blockscout-error-logs-bucket

# S3 prefix/path for error logs (e.g., "blockscout/errors")
S3_LOG_PREFIX=blockscout/errors

# AWS region for S3 operations
AWS_REGION=ap-northeast-1

# -----------------------------------------------------------------------------
# Scanner Configuration
# -----------------------------------------------------------------------------
# Scan interval in seconds (default: 300 = 5 minutes)
SCAN_INTERVAL=300

# Maximum age of logs to process in seconds (default: 86400 = 24 hours)
MAX_LOG_AGE=86400

# Log directories (can be overridden via environment variables)
# LOG_DIR=/logs
# NGINX_LOG_DIR=/logs/nginx
# BACKEND_LOG_DIR=/logs/backend

# -----------------------------------------------------------------------------
# AWS Credentials (Optional)
# -----------------------------------------------------------------------------
# Note: If using IAM roles (recommended), these are not needed.
# If not using IAM roles, uncomment and set these values.
# WARNING: Do not commit credentials to version control!
# AWS_ACCESS_KEY_ID=your-access-key-id
# AWS_SECRET_ACCESS_KEY=your-secret-access-key

# Skip AWS credentials check (useful for local development)
# Set to "true" to skip AWS credentials validation
AWS_SKIP_AWS_CHECK=false

# -----------------------------------------------------------------------------
# Slack Notification Configuration
# -----------------------------------------------------------------------------
# Slack webhook URL for sending error alerts
# Get this from: https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=https://api.slack.com/messaging/webhooks

# Slack username for notifications
SLACK_USERNAME=Error Scanner

# Slack icon emoji for notifications
SLACK_ICON_EMOJI=:warning:

# -----------------------------------------------------------------------------
# Notification Tracking Configuration
# -----------------------------------------------------------------------------
# Retention period for notification tracking in hours
# Used only for manual cleanup (automatic cleanup is disabled)
NOTIFICATION_RETENTION_HOURS=24
