# Error Scanner Configuration
# Configuration for error log scanning and S3 upload

# S3 Configuration
S3_ERROR_LOGS_BUCKET=oasys-blockscout-error-logs-bucket
S3_LOG_PREFIX=blockscout/errors
AWS_REGION=ap-northeast-1

# Scanner Configuration
SCAN_INTERVAL=300
MAX_LOG_AGE=86400

# Optional: AWS Credentials (if not using IAM roles)
# AWS_ACCESS_KEY_ID=xxxxx
# AWS_SECRET_ACCESS_KEY=xxxxx

# Slack Configuration
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK
# SLACK_CHANNEL=#blockscout-alerts
# SLACK_USERNAME=Error Scanner
# SLACK_ICON_EMOJI=:warning:
